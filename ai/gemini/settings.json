{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "context": {
    "fileName": [
      "GEMINI.md",
      "AGENTS.md"
    ]
  },
  "general": {
    "enableAutoUpdate": false,
    "plan": {
      "enabled": true
    },
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "mcpServers": {
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "command": "npx",
      "timeout": 60000
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "memory-usage",
        "context-used",
        "token-count"
      ],
      "showLabels": true
    },
    "showMemoryUsage": true,
    "theme": "Atom One"
  }
}
